  "agentSettings": {
    "_doc": "GUI 토글 매핑. 정확한 키 명은 실제 설치 후 GUI 토글 → settings.json diff로 확정 필요.",
    "terminalExecutionPolicy": "off",
    "nonWorkspaceFileAccess": false,
    "browserDomainAllowlist": [],
    "browserDomainDenylist": ["webhook.site", "*.webhook.site", "requestbin.com", "*.requestbin.com"],
    "mcpToolApproval": "manual",
    "artifactReviewPolicy": "request_review",
    "gitignoreAccess": false,
    "autoFixLints": false,
    "autoContinue": false
  },
  "hooks": {
    "_doc": "Antigravity 2.0 hooks. 이벤트 명칭(before_tool_call 등)은 secondary 소스 기준 추정 — 실제 설치 후 확정 필요. Claude Code의 PreToolUse 훅 재사용.",
    "before_tool_call": [
      {
        "matcher": "Bash",
        "command": "$HOME/.antigravity/hooks/auto-approve-readonly.sh"
      },
      {
        "matcher": "Write|Edit",
        "pattern": "**/.agent/mcp_config.json",
        "command": "$HOME/.antigravity/hooks/mcp-config-guard.sh"
      },
      {
        "matcher": "Write|Edit",
        "pattern": "**/.agents/mcp_config.json",
        "command": "$HOME/.antigravity/hooks/mcp-config-guard.sh"
      }
    ]
  },
