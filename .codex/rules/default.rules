# ─────────────────────────────────────────────
# Codex 실행 정책 (Execution Policy)
# approval_policy = "never" + sandbox_mode = "danger-full-access" 조합에서 위험 명령어만 차단
# (v0.128부터 --full-auto는 deprecated. 우리는 permission profiles 대신 본 Starlark DSL로 직접 통제)
# Claude Code의 auto-approve-readonly.sh에 대응
# ─────────────────────────────────────────────

# ── 파일 삭제/파괴 (비가역적) ──
prefix_rule(
    pattern = ["rm"],
    decision = "forbidden",
    justification = "파일 삭제 명령어 차단"
)

prefix_rule(
    pattern = ["rmdir"],
    decision = "forbidden",
    justification = "디렉토리 삭제 명령어 차단"
)

prefix_rule(
    pattern = ["unlink"],
    decision = "forbidden",
    justification = "파일 삭제 명령어 차단"
)

prefix_rule(
    pattern = ["shred"],
    decision = "forbidden",
    justification = "파일 파쇄 명령어 차단"
)

prefix_rule(
    pattern = ["truncate"],
    decision = "forbidden",
    justification = "파일 절단 명령어 차단"
)

# ── 시스템 (위험) ──
prefix_rule(
    pattern = ["reboot"],
    decision = "forbidden",
    justification = "시스템 재부팅 차단"
)

prefix_rule(
    pattern = ["shutdown"],
    decision = "forbidden",
    justification = "시스템 종료 차단"
)

prefix_rule(
    pattern = ["poweroff"],
    decision = "forbidden",
    justification = "시스템 종료 차단"
)

prefix_rule(
    pattern = ["halt"],
    decision = "forbidden",
    justification = "시스템 정지 차단"
)

# ── sudo (권한 상승 + 비밀번호 프롬프트) ──
prefix_rule(
    pattern = ["sudo"],
    decision = "forbidden",
    justification = "sudo 차단 — 비밀번호 프롬프트로 작업이 중단됨"
)

# ── 프로세스 종료 ──
prefix_rule(
    pattern = ["kill"],
    decision = "forbidden",
    justification = "프로세스 강제 종료 차단"
)

prefix_rule(
    pattern = ["pkill"],
    decision = "forbidden",
    justification = "프로세스 강제 종료 차단"
)

prefix_rule(
    pattern = ["killall"],
    decision = "forbidden",
    justification = "프로세스 강제 종료 차단"
)

# ── 디스크 (비가역적) ──
prefix_rule(
    pattern = ["dd"],
    decision = "forbidden",
    justification = "디스크 직접 쓰기 차단"
)

prefix_rule(
    pattern = ["mkfs"],
    decision = "forbidden",
    justification = "파일시스템 포맷 차단"
)

prefix_rule(
    pattern = ["fdisk"],
    decision = "forbidden",
    justification = "디스크 파티션 조작 차단"
)

prefix_rule(
    pattern = ["parted"],
    decision = "forbidden",
    justification = "디스크 파티션 조작 차단"
)

# ── Git 쓰기 (비가역적/공유 영향) ──
prefix_rule(
    pattern = ["git", "rm"],
    decision = "forbidden",
    justification = "파일 삭제 차단 — git rm 경로"
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "forbidden",
    justification = "원격 푸시 차단 — 수동으로 실행"
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "forbidden",
    justification = "커밋 차단 — 수동으로 실행"
)

prefix_rule(
    pattern = ["git", "reset"],
    decision = "forbidden",
    justification = "커밋 리셋 차단"
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "forbidden",
    justification = "untracked 파일 삭제 차단"
)

prefix_rule(
    pattern = ["git", "rebase"],
    decision = "forbidden",
    justification = "리베이스 차단"
)

prefix_rule(
    pattern = ["git", "merge"],
    decision = "forbidden",
    justification = "머지 차단"
)

prefix_rule(
    pattern = ["git", "cherry-pick"],
    decision = "forbidden",
    justification = "체리픽 차단"
)

prefix_rule(
    pattern = ["git", "revert"],
    decision = "forbidden",
    justification = "리버트 차단"
)

prefix_rule(
    pattern = ["git", "am"],
    decision = "forbidden",
    justification = "패치 적용 차단"
)

prefix_rule(
    pattern = ["git", "apply"],
    decision = "forbidden",
    justification = "패치 적용 차단"
)

# ── Git 상태 변경 (working tree/HEAD 이동) ──
# checkout/switch: 브랜치 전환 시 작업 컨텍스트 손실 + detached HEAD 위험
# restore: working tree 변경 폐기 위험
prefix_rule(
    pattern = ["git", "checkout"],
    decision = "forbidden",
    justification = "체크아웃 차단 — 작업 컨텍스트 손실 + working tree 변경 폐기 위험"
)

prefix_rule(
    pattern = ["git", "switch"],
    decision = "forbidden",
    justification = "브랜치 전환 차단 — 작업 컨텍스트 손실 위험"
)

prefix_rule(
    pattern = ["git", "restore"],
    decision = "forbidden",
    justification = "restore 차단 — working tree 변경 폐기 위험"
)

# ── Git 삭제 (비가역적) ──
# 삭제 플래그만 차단, 읽기(git branch -a, git tag -l 등)는 허용
# forbidden > allow 우선이므로, allow와 forbidden이 동시 매칭되면 forbidden 적용
prefix_rule(
    pattern = ["git", "branch", ["-d", "-D", "--delete"]],
    decision = "forbidden",
    justification = "브랜치 삭제 차단"
)

prefix_rule(
    pattern = ["git", "stash"],
    decision = "forbidden",
    justification = "stash 차단 — working tree 비우는 상태 변경 위험 (list/show 포함 전체 차단)"
)

prefix_rule(
    pattern = ["git", "tag", ["-d", "-f", "--delete"]],
    decision = "forbidden",
    justification = "태그 삭제/덮어쓰기 차단"
)

# ── Git 읽기 명령은 허용 ──
# stash는 위 forbidden 규칙 우선 적용됨 (working tree 변경 위험)
prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show", "blame", "fetch", "remote", "branch", "tag"]],
    decision = "allow"
)

# ── GitHub CLI 쓰기 ──
prefix_rule(
    pattern = ["gh", ["pr", "issue", "release", "repo"], ["create", "close", "delete", "merge", "edit", "comment"]],
    decision = "forbidden",
    justification = "GitHub 리소스 변경 차단"
)

prefix_rule(
    pattern = ["gh", "auth", ["login", "logout"]],
    decision = "forbidden",
    justification = "GitHub 인증 변경 차단"
)

prefix_rule(
    pattern = ["gh", "api"],
    decision = "forbidden",
    justification = "GitHub API 직접 호출 차단 — 쓰기 작업 가능하므로 차단"
)

# ── GitHub CLI 읽기는 허용 ──
prefix_rule(
    pattern = ["gh", ["pr", "issue", "release", "repo"], ["list", "view", "status", "checks", "diff"]],
    decision = "allow"
)

# ── Docker 삭제 ──
prefix_rule(
    pattern = ["docker", ["rm", "rmi"]],
    decision = "forbidden",
    justification = "Docker 리소스 삭제 차단"
)

prefix_rule(
    pattern = ["docker-compose", ["down", "rm"]],
    decision = "forbidden",
    justification = "Docker Compose 리소스 삭제 차단"
)

prefix_rule(
    pattern = ["docker", "compose", ["down", "rm"]],
    decision = "forbidden",
    justification = "Docker Compose 리소스 삭제 차단"
)

# ── A 그룹: 명확히 위험한 상태 변경 명령 ──
# 영향도가 적은 read-only 명령만 자동 허용 원칙
# 갭 인정: sed -i (옵션 위치 다양), 리다이렉트(>/>>)는 prefix_rule로 처리 불가 → AGENTS.md 안내

# cp/mv: 경로 변경·복사로 되돌리기 쉬워 allow
# (Starlark prefix_rule은 옵션 매칭 어려워 ln도 통째로 차단 유지)

prefix_rule(
    pattern = ["ln"],
    decision = "forbidden",
    justification = "ln 차단 — -f/-sf force overwrite 위험 (prefix_rule 한계로 ln 통째로 차단)"
)

prefix_rule(
    pattern = ["chmod"],
    decision = "forbidden",
    justification = "chmod 차단 — 권한 변경"
)

prefix_rule(
    pattern = ["chown"],
    decision = "forbidden",
    justification = "chown 차단 — 소유자 변경"
)

prefix_rule(
    pattern = ["sed", "-i"],
    decision = "forbidden",
    justification = "sed -i 차단 — 파일 in-place 수정 (옵션 위치가 첫 인자일 때만 매칭)"
)

prefix_rule(
    pattern = ["git", "add"],
    decision = "forbidden",
    justification = "git add 차단 — staging 상태 변경"
)
